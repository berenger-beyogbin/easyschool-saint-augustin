# ===========================================================
# EASY SCHOOL 2.0 — .env.example
# FICHIER MODÈLE — NE CONTIENT AUCUNE DONNÉE RÉELLE
# ===========================================================
# INSTRUCTIONS :
#   1. Copier ce fichier et le renommer en .env
#   2. Remplir les valeurs réelles (mot de passe PostgreSQL, etc.)
#   3. NE JAMAIS committer le fichier .env sur Git / GitHub
# ===========================================================

# === CONNEXION POSTGRESQL ===
DB_HOST=localhost
DB_PORT=5432
DB_NAME=easy_school_cjga_db
DB_USER=postgres
DB_PASSWORD=CHANGE_ME

# === MODE APPLICATION ===
# Valeurs possibles : dev | dev_debug | prod
# - dev         : messages d'erreur affichés, echo SQL désactivé
# - dev_debug   : echo SQL activé (flood de requêtes dans la console)
# - prod        : mode production, logs minimaux
APP_ENV=dev
